{
  "name": "istqb-foundation-4-study-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "An unofficial, interactive study lab for ISTQB Certified Tester Foundation Level 4.0 preparation.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "keywords": [
    "istqb",
    "ctfl",
    "software-testing",
    "quiz",
    "learning"
  ],
  "author": "Darek Wojciechowski",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darekwojciechowski/istqb-foundation-4-study-lab.git"
  },
  "bugs": {
    "url": "https://github.com/darekwojciechowski/istqb-foundation-4-study-lab/issues"
  },
  "homepage": "https://darekwojciechowski.github.io/istqb-foundation-4-study-lab/",
  "engines": {
    "node": ">=26"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
